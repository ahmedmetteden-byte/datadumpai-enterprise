# Public marketing site URL (canonical, OG, sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.getdatadump.com

# Streamlit application URL — change when migrating to app.getdatadump.com
NEXT_PUBLIC_APP_URL=https://www.getdatadump.com

# Contact form destination (wire to your email/API in production)
NEXT_PUBLIC_CONTACT_EMAIL=hello@getdatadump.com

# Google Analytics 4 — production only (leave empty for local dev)
# Find in GA4: Admin → Data Streams → Web → Measurement ID (format G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Sentry error monitoring — production only (leave empty to disable)
# Create a project at https://sentry.io, then paste the DSN here.
# Install @sentry/nextjs and complete src/lib/monitoring/sentry-adapter.ts to activate.
NEXT_PUBLIC_SENTRY_DSN=
