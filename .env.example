# OpenAI
OPENAI_API_KEY=your-openai-api-key

# ---------------------------------------------------------------------------
# Supabase Authentication (required for production)
# ---------------------------------------------------------------------------
# Create a Supabase project and enable:
#   - Email authentication
#   - Email confirmation
#   - Password reset
# Disable anonymous sign-ins.
#
# SUPABASE_ANON_KEY is safe for the frontend.
# SUPABASE_SERVICE_ROLE_KEY must stay on the server only — never expose it
# to the browser or commit it to version control.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# Where Supabase redirects after email verification or password reset
AUTH_REDIRECT_URL=http://localhost:8501

# Local development only — bypasses Supabase and uses an isolated dev user.
# Must be false in production.
AUTH_DEV_BYPASS=false

# ---------------------------------------------------------------------------
# Data storage
# ---------------------------------------------------------------------------

# Metadata storage: supabase (PostgreSQL) recommended for production
DATABASE_BACKEND=supabase

# File storage: supabase (Supabase Storage) recommended for production
STORAGE_BACKEND=supabase
SUPABASE_STORAGE_BUCKET=datadumpai-files

# Required when DATABASE_BACKEND=supabase (or AUTH_DEV_BYPASS=true with Supabase DB)
# SUPABASE_SERVICE_ROLE_KEY is set above.

# Account lockout (failed sign-in attempts)
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Payments (Stripe + Paystack)
PAYMENTS_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_STARTER_AMOUNT_CENTS=1500
STRIPE_PROFESSIONAL_AMOUNT_CENTS=3900

PAYSTACK_SECRET_KEY=
PAYSTACK_STARTER_PLAN_CODE=
PAYSTACK_PROFESSIONAL_PLAN_CODE=
PAYSTACK_STARTER_AMOUNT_KOBO=1500000
PAYSTACK_PROFESSIONAL_AMOUNT_KOBO=3900000

BILLING_SUCCESS_URL=http://localhost:8501
BILLING_CANCEL_URL=http://localhost:8501
BILLING_WEBHOOK_BASE_URL=http://localhost:8000

# Email notifications
EMAIL_ENABLED=false
EMAIL_FROM=noreply@datadumpai.com
EMAIL_FROM_NAME=DataDumpAI
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
RESEND_API_KEY=

# Admin access (comma-separated)
ADMIN_USER_IDS=
ADMIN_EMAILS=

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=local
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
PLAUSIBLE_DOMAIN=

# Launch
SITE_URL=https://www.getdatadump.com
DEBUG=false
